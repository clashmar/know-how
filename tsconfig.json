{
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "types": ["node"],
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@samfp/pi-memory": ["./node_modules/@samfp/pi-memory/src/index.ts"],
      "@samfp/pi-memory/store": ["./node_modules/@samfp/pi-memory/src/store.ts"],
      "@earendil-works/pi-tui": ["./node_modules/@earendil-works/pi-tui/src/index.ts"],
      "@earendil-works/pi-coding-agent": ["./node_modules/@mariozechner/pi-coding-agent/dist/index.d.ts"]
    }
  },
  "include": ["extension/**/*.ts"],
  "exclude": [
    "extension/skills/systematic-debugging/condition-based-waiting-example.ts"
  ]
}
