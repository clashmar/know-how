#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ -n "${PI_CONFIG_DIR:-}" ]; then
    CONFIG_DIR="$PI_CONFIG_DIR"
elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
    CONFIG_DIR="$XDG_CONFIG_HOME/pi-agent"
else
    CONFIG_DIR="$HOME/.pi/agent"
fi

EXTENSION_DIR="$CONFIG_DIR/extensions"
EXTENSION_KNOW_HOW_DIR="$EXTENSION_DIR/know-how"
SKILLS_LINK="$CONFIG_DIR/skills/know-how"

# Remove the extension
rm -rf "$EXTENSION_KNOW_HOW_DIR"

# Remove legacy artifacts
rm -f "$EXTENSION_DIR/know-how.ts"
rm -rf "$SKILLS_LINK"

# Clean up any agents installed by older versions of this script
if [ -d "$REPO_ROOT/extension/agents" ]; then
    for agent_file in "$REPO_ROOT/extension/agents"/*.md; do
        if [ -f "$agent_file" ]; then
            agent_name="$(basename "$agent_file")"
            rm -f "$CONFIG_DIR/agents/$agent_name"
        fi
    done
fi

echo "Removed know-how extension: $EXTENSION_KNOW_HOW_DIR"
