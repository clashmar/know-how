#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ -n "${PI_CONFIG_DIR:-}" ]; then
    CONFIG_DIR="$PI_CONFIG_DIR"
elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
    CONFIG_DIR="$XDG_CONFIG_HOME/pi-agent"
else
    CONFIG_DIR="$HOME/.pi/agent"
fi

SOURCE_EXTENSION_FILE="$REPO_ROOT/extensions/know-how.ts"
SOURCE_SKILLS_DIR="$REPO_ROOT/skills"
SOURCE_AGENTS_DIR="$REPO_ROOT/.pi/agents"
EXTENSION_DIR="$CONFIG_DIR/extensions"
EXTENSION_FILE="$EXTENSION_DIR/know-how.ts"
SKILLS_LINK="$CONFIG_DIR/skills/know-how"
AGENTS_DIR="$CONFIG_DIR/agents"

if [ ! -f "$SOURCE_EXTENSION_FILE" ]; then
    echo "Source extension not found: $SOURCE_EXTENSION_FILE" >&2
    exit 1
fi

if [ ! -d "$SOURCE_SKILLS_DIR" ]; then
    echo "Source skills directory not found: $SOURCE_SKILLS_DIR" >&2
    exit 1
fi

mkdir -p "$EXTENSION_DIR"
mkdir -p "$(dirname "$SKILLS_LINK")"
mkdir -p "$AGENTS_DIR"

rm -f "$EXTENSION_FILE"
rm -rf "$SKILLS_LINK"

cp "$SOURCE_EXTENSION_FILE" "$EXTENSION_FILE"
ln -sf "$SOURCE_SKILLS_DIR" "$SKILLS_LINK"

# Install agents
if [ -d "$SOURCE_AGENTS_DIR" ]; then
    for agent_file in "$SOURCE_AGENTS_DIR"/*.md; do
        if [ -f "$agent_file" ]; then
            agent_name="$(basename "$agent_file")"
            cp "$agent_file" "$AGENTS_DIR/$agent_name"
            echo "Agent:     $AGENTS_DIR/$agent_name"
        fi
    done
fi

echo ""
echo "Installed know-how for pi into $CONFIG_DIR"
echo "Extension: $EXTENSION_FILE"
echo "Skills:    $SKILLS_LINK -> $SOURCE_SKILLS_DIR"
echo ""
echo "The extension auto-discovers skills, so the symlink is optional but"
echo "useful for /skills browsing. The extension's resources_discover hook"
echo "points directly to the repo's skills/ directory."
